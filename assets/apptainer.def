Bootstrap: docker
From: nvidia/cuda:12.2.2-devel-ubuntu22.04

%labels
    Author  "unknown"
    Version "hf_env-1.0"

%environment
    . /opt/conda/etc/profile.d/conda.sh
    conda activate hf_env

%files
    /path/to/CLIP   /opt/CLIP

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # Apptainer builds often have /tmp mounted with weird flags; use a safe temp dir
    export TMPDIR=/var/tmp
    mkdir -p /var/tmp

    ### 1) OS deps
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates curl git build-essential \
        pkg-config
    rm -rf /var/lib/apt/lists/*

    ### 2) Install Miniconda (CPython-friendly, avoids mamba/libmamba weirdness)
    curl -fsSL -o /tmp/miniconda.sh \
      https://repo.anaconda.com/miniconda/Miniconda3-py310_25.3.1-1-Linux-x86_64.sh
    bash /tmp/miniconda.sh -b -p /opt/conda
    rm -f /tmp/miniconda.sh

    ln -s /opt/conda/etc/profile.d/conda.sh /etc/profile.d/conda.sh
    echo ". /opt/conda/etc/profile.d/conda.sh" >> /etc/bash.bashrc
    echo "conda activate hf_env" >> /etc/bash.bashrc

    . /opt/conda/etc/profile.d/conda.sh

    ### 3) Create env (force CPython build)
    conda create -y -n hf_env python=3.10
    conda activate hf_env
    conda install -y -c conda-forge ffmpeg

    # keep pip sane
    python -m pip install --upgrade pip wheel
    # Older CLIP setup.py imports pkg_resources; keep a setuptools version that still provides it.
    python -m pip install "setuptools<82"

    python -m pip install 'torch>=2.4' torchvision

    python -m pip install 'transformers>=4.53' accelerate uvicorn fastapi termcolor 'qwen-vl-utils[decord]'

    python -m pip install scipy
    python -m pip install pytorchvideo
    python -m pip install zstandard

    # Minimal extras needed by motion_only_AR/models/video_features for I3D/RAFT extraction.
    # Do not install torchaudio here: for this path it is unnecessary and can pull a mismatched torch build.
    python -m pip install torchao ffmpeg-python imageio timm bitsandbytes==0.45.4
    # Install ultralytics without deps, then add the runtime subset we actually want without GUI OpenCV.
    python -m pip install --no-cache-dir --no-deps ultralytics==8.4.21
    python -m pip install matplotlib polars ultralytics-thop psutil py-cpuinfo pyyaml requests
    python -m pip install omegaconf tqdm h5py

    # Avoid isolated build env pulling a setuptools variant without pkg_resources.
    python -m pip install --no-cache-dir --no-build-isolation /opt/CLIP

    # Keep headless OpenCV as the final state in case a later dependency pulled GUI OpenCV.
    python -m pip uninstall -y opencv-python opencv-contrib-python opencv-contrib-python-headless opencv-python-headless || true
    python -m pip install --no-cache-dir --force-reinstall --no-deps "opencv-python-headless==4.10.0.84"
    python -m pip install tensorboard

    conda clean -afy

%runscript
    exec /bin/bash -c ". /opt/conda/etc/profile.d/conda.sh && conda activate hf_env && exec \"\$@\""
